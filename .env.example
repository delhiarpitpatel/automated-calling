# ==================== AUDIO SETTINGS ====================
# Run `python -m sounddevice` to find your device IDs
# Leave blank for auto-detection
INPUT_DEVICE=
OUTPUT_DEVICE=

# Audio sample rate (must be 16000 for VAD/STT models)
SAMPLE_RATE=16000
CHANNELS=1

# Audio chunk size: 512 samples @ 16kHz = 32ms
# Decrease for lower latency (higher CPU), increase for stability
CHUNK_SIZE=512

# ==================== VAD SETTINGS ====================
# Voice Activity Detection threshold (0.0 to 1.0)
# Lower = more sensitive to noise
# Higher = might miss quiet speech
# Recommended: 0.5 (very sensitive) to 0.85 (balanced)
VAD_THRESHOLD=0.8

# Number of consecutive silent chunks before processing
# 30 chunks * 32ms = ~1 second of silence
# Decrease for faster response, increase for robustness
SILENCE_LIMIT_CHUNKS=30

# ==================== SPEECH-TO-TEXT ====================
# Model: "tiny.en" (fastest), "base.en" (balanced), "small.en" (better)
# For AMD APU / 8GB RAM, stick with "tiny.en"
STT_MODEL=tiny.en
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_CPU_THREADS=4
STT_NUM_WORKERS=1

# ==================== LLM SETTINGS ====================
# Ollama must be running: `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_REQUEST_TIMEOUT=30.0

# ==================== TEXT-TO-SPEECH ====================
# Directory containing .onnx voice models
VOICE_MODEL_DIR=models/voices
VOICE_MODEL_NAME=en_US-lessac-medium

# Upsample TTS audio from 22050 Hz to 44100 Hz
# Set to "true" for Bluetooth speakers, "false" for direct audio
UPSAMPLE_TTS_AUDIO=true

# Temporary file for audio synthesis (cleaned up automatically)
TTS_TEMP_FILE=temp_output.wav

# ==================== N8N WEBHOOK INTEGRATION ====================
# Leave blank to disable n8n integration
N8N_WEBHOOK_URL=
N8N_REQUEST_TIMEOUT=10.0
N8N_RETRY_ATTEMPTS=2

# ==================== LOGGING ====================
LOG_LEVEL=INFO
DEBUG_AUDIO_INPUT=false
